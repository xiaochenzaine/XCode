{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "`", "close": "`" }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "`", "close": "`" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\b(if|elseif|else|foreach|function|macro|while|block)\\b.*$",
    "decreaseIndentPattern": "^\\s*\\b(endif|elseif|else|endforeach|endfunction|endmacro|endwhile|endblock)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "\\b(if|elseif|else|foreach|function|macro|while|block)\\b.*$",
      "afterText": "^\\s*\\b(endif|elseif|else|endforeach|endfunction|endmacro|endwhile|endblock)\\b",
      "action": { "indent": "indent" }
    }
  ]
}